            },
            "32bit": {
                "url": "https://github.com/brechtsanders/winlibs_mingw/releases/download/$matchFull/winlibs-i686-posix-dwarf-gcc-$matchGcc-mingw-w64msvcrt-$matchMingw-r$matchRelease.7z"
