{
    "version": "26.04-7407",
    "description": "Universal document viewer",
    "homepage": "https://okular.kde.org",
    "license": "GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://cdn.kde.org/ci-builds/graphics/okular/release-26.04/windows/okular-release_26.04-7407-windows-cl-msvc2022-x86_64.7z",
            "hash": "39a3560c9b2b74452768349f15630711b962e1eaa1e7c9cc44ef69b8a42f4072"
        }
    },
    "bin": "bin\\okular.exe",
    "shortcuts": [
        [
            "bin\\okular.exe",
            "Okular"
        ]
    ],
    "checkver": {
        "script": [
            "$relRes = $(Invoke-WebRequest 'https://cdn.kde.org/ci-builds/graphics/okular/?C=M;O=D').Content",
            "$relRes -match 'release-([\\d.]+)'",
            "$major = $Matches.1",
            "$verRes = $(Invoke-WebRequest \"https://cdn.kde.org/ci-builds/graphics/okular/release-$major/windows/\").Content",
            "$verRes -match \"okular-release_$major-(\\d+)\"",
            "$build = $Matches.1",
            "\"$major-$build\""
        ],
        "regex": "((?<release>[\\d.]+)-\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.kde.org/ci-builds/graphics/okular/release-$matchRelease/windows/okular-release_$version-windows-cl-msvc2022-x86_64.7z",
                "hash": {
                    "url": "$url.sha256"
                }
            }
        }
    }
}
