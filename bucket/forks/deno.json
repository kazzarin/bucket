            },
            "arm64": {
                "url": "https://dl.deno.land/release/v$version/deno-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256sum",
            "regex": "$sha256"
        }
    }
}
