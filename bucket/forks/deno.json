{
    "version": "2.8.3",
    "description": "A secure runtime for JavaScript and TypeScript",
    "homepage": "https://deno.com",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://dl.deno.land/release/v2.8.3/deno-x86_64-pc-windows-msvc.zip",
            "hash": "7fdd1f42e6b0855421ecf27bb406e2492ade1087c85e30ebf0deab6280ea743c"
        },
        "arm64": {
            "url": "https://dl.deno.land/release/v2.8.3/deno-aarch64-pc-windows-msvc.zip",
            "hash": "243f478ac577ade1bbd980ecf510607a10ed8cc977b462083ada48e5f6580de1"
        }
    },
    "bin": [
        "deno.exe",
        [
            "deno.exe",
            "dx",
            "x"
        ]
    ],
    "checkver": {
        "url": "https://dl.deno.land/release-latest.txt",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl.deno.land/release/v$version/deno-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://dl.deno.land/release/v$version/deno-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256sum",
            "regex": "$sha256"
        }
    }
}
