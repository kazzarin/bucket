        }
    },
    "bin": [
        "deno.exe",
        [
            "deno.exe",
            "dx",
            "x"
        ]
    ],
    "checkver": {
        "url": "https://dl.deno.land/release-latest.txt",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
